generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  auth0Id        String          @unique
  email          String          @unique
  name           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  credits        Int             @default(100)
  language       String          @default("en")
  plan           String          @default("one-time")
  creditsRefill  Int             @default(1000)
  projects       Project[]
  transcriptions Transcription[]
}

model Project {
  id             String          @id @default(uuid())
  name           String
  userId         String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  transcriptions Transcription[]
  user           User            @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Transcription {
  id                        String             @id @default(uuid())
  userId                    String
  projectId                 String?
  title                     String             @default("")
  audioFileKey              String
  audioFileName             String
  audioFileSize             Int
  transcription             Json?
  language                  String
  vocabulary                String[]
  speakerCount              Int                @default(1)
  state                     TranscriptionState @default(PENDING)
  errorMessage              String?
  elevenLabsTranscriptionId String?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  updatedBy                 String             @default("system")
  completedAt               DateTime?
  user                      User               @relation(fields: [userId], references: [id])
  project                   Project?           @relation(fields: [projectId], references: [id])

  @@index([id])
  @@index([userId, id])
  @@index([userId, projectId])
  @@index([userId, state])
  @@index([userId, createdAt])
}

enum TranscriptionState {
  PENDING
  COMPLETED
  ERROR
}

model TranscriptionHistory {
  id              String   @id @default(uuid())
  transcriptionId String
  userId          String
  transcription   Json?
  updatedAt       DateTime @updatedAt
  updatedBy       String

  @@index([userId, transcriptionId, updatedAt])
}
