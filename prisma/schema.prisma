generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String          @id @default(uuid())
  auth0Id                String          @unique
  email                  String          @unique
  name                   String?
  passwordHash           String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  credits                Int             @default(100)
  language               String          @default("en")
  plan                   String          @default("free")
  creditsRefill          Int             @default(100)
  creditsUsed            Int             @default(0)
  publicKey              String?
  trustedDeviceSecret    String?
  stripeCustomerId       String?         @unique
  stripeSubscriptionId   String?         @unique
  subscriptionPeriodEnd  DateTime?
  subscriptionStatus     String?
  lastCreditsRefill      DateTime?
  shortcuts              Json?
  projects               Project[]
  transcriptions         Transcription[]
  feedbacks              Feedback[]
  deletionTokens         DeletionToken[]
  isWelcomeDone          Boolean         @default(false)
}

model Project {
  id             String          @id @default(uuid())
  name           String
  userId         String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  transcriptions Transcription[]
  user           User            @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Transcription {
  id                        String                        @id @default(uuid())
  userId                    String
  projectId                 String?
  title                     String                        @default("")
  audioFileKey              String
  audioFileEncryption       Json?
  audioFileName             String
  audioFileSize             Int
  transcription             Json?
  isTutorial                Boolean                       @default(false)
  language                  String
  vocabulary                String[]
  speakerCount              Int                           @default(1)
  state                     TranscriptionState            @default(PENDING)
  errorMessage              String?
  elevenLabsTranscriptionId String?
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt
  updatedBy                 String                        @default("system")
  completedAt               DateTime?
  user                      User                          @relation(fields: [userId], references: [id])
  project                   Project?                      @relation(fields: [projectId], references: [id])

  @@index([id])
  @@index([userId, id])
  @@index([userId, projectId])
  @@index([userId, state])
  @@index([userId, createdAt])
}

enum TranscriptionState {
  PENDING
  COMPLETED
  ERROR
}

model TranscriptionHistory {
  id              String   @id @default(uuid())
  transcriptionId String
  userId          String
  transcription   Json?
  updatedAt       DateTime @updatedAt
  updatedBy       String
  additions       Int      @default(0)
  removals        Int      @default(0)
  changed         Int      @default(0)

  @@index([userId, transcriptionId, updatedAt])
}

model Feedback {
  id        String       @id @default(uuid())
  userId    String
  type      FeedbackType @default(RATING)
  rating    Int?
  message   String?
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([type])
}

enum FeedbackType {
  RATING
  FEATURE_REQUEST
}

model DeletionToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}
