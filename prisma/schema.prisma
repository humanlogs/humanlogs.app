generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(uuid())
  auth0Id        String          @unique
  email          String          @unique
  name           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  credits        Int             @default(0)
  language       String          @default("en")
  plan           String          @default("one-time")
  creditsRefill  Int             @default(1000)
  projects       Project[]
  transcriptions Transcription[]
}

model Project {
  id             String          @id @default(uuid())
  name           String
  userId         String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  transcriptions Transcription[]

  @@index([userId])
}

model Transcription {
  id                        String             @id @default(uuid())
  userId                    String
  projectId                 String?
  title                     String             @default("")
  audioFileKey              String
  audioFileName             String
  audioFileSize             Int
  transcription             Json?
  language                  String
  vocabulary                String[]
  speakerCount              Int                @default(1)
  state                     TranscriptionState @default(PENDING)
  errorMessage              String?
  elevenLabsTranscriptionId String?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  completedAt               DateTime?

  @@index([userId])
  @@index([userId, projectId])
  @@index([userId, state])
  @@index([userId, createdAt])
}

enum TranscriptionState {
  PENDING
  COMPLETED
  ERROR
}

model TranscriptionHistory {
  id                        String             @id @default(uuid())
  transcriptionId           String
  userId                    String
  transcription             Json?
  updatedAt                 DateTime           @updatedAt

  @@index([userId, transcriptionId, updatedAt])
}
