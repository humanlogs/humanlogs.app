{
    "auth": {
        "mode": "AUTH_MODE",
        "sessionSecret": "AUTH_SESSION_SECRET",
        "auth0": {
            "secret": "AUTH0_SECRET",
            "baseUrl": "AUTH0_BASE_URL",
            "issuerBaseUrl": "AUTH0_ISSUER_BASE_URL",
            "clientId": "AUTH0_CLIENT_ID",
            "clientSecret": "AUTH0_CLIENT_SECRET"
        },
        "ldap": {
            "enabled": "LDAP_ENABLED",
            "url": "LDAP_URL",
            "bindDN": "LDAP_BIND_DN",
            "bindPassword": "LDAP_BIND_PASSWORD",
            "searchBase": "LDAP_SEARCH_BASE",
            "searchFilter": "LDAP_SEARCH_FILTER"
        }
    },
    "database": {
        "url": "DATABASE_URL"
    },
    "aws": {
        "accessKeyId": "AWS_ACCESS_KEY_ID",
        "accessKeySecret": "AWS_ACCESS_KEY_SECRET",
        "region": "AWS_REGION",
        "s3": {
            "bucketName": "S3_BUCKET_NAME"
        }
    },
    "elevenlabs": {
        "apiKey": "ELEVENLABS_API_KEY",
        "canDisableStorage": "ELEVENLABS_CAN_DISABLE_STORAGE"
    },
    "stripe": {
        "secretKey": "STRIPE_SECRET",
        "webhookSecret": "STRIPE_WEBHOOK_SECRET",
        "prices": {
            "monthlySubscription": "STRIPE_PRICE_MONTHLY_SUBSCRIPTION",
            "yearlySubscription": "STRIPE_PRICE_YEARLY_SUBSCRIPTION",
            "oneTimeCredits": "STRIPE_PRICE_ONE_TIME_CREDITS"
        }
    },
    "email": {
        "provider": "EMAIL_PROVIDER",
        "from": {
            "name": "EMAIL_FROM_NAME",
            "address": "EMAIL_FROM_ADDRESS"
        },
        "smtp": {
            "host": "SMTP_HOST",
            "port": "SMTP_PORT",
            "secure": "SMTP_SECURE",
            "auth": {
                "user": "SMTP_USER",
                "pass": "SMTP_PASSWORD"
            }
        },
        "ses": {
            "region": "SES_REGION"
        }
    },
    "server": {
        "publicUrl": "NEXT_PUBLIC_APP_URL",
        "port": "SERVER_PORT"
    }
}